			lineageTag: e82b2511-bb16-4e76-8fb9-9be80f2d2d31
			column: Date

	partition DIM_DATE = calculated
		mode: import
		source = ```
				
				VAR StartDate = DATE(1990, 1, 1)
				VAR EndDate = DATE(2030, 12, 31)
				
				RETURN
				ADDCOLUMNS(
				    CALENDAR(StartDate, EndDate),
				    
				    -- Basic date parts
				    "DateKey",          FORMAT([Date], "YYYYMMDD") + 0,
				    "Year",             YEAR([Date]),
				    "MonthNumber",      MONTH([Date]),
				    "MonthName",        FORMAT([Date], "MMMM"),
				    "MonthShort",       FORMAT([Date], "MMM"),
				    "Quarter",          QUARTER([Date]),
				    "QuarterName",      "Q" & QUARTER([Date]),
				    "DayOfMonth",       DAY([Date]),
				    "DayOfWeekNumber",  WEEKDAY([Date], 2),  -- 1=Monday, 7=Sunday
				    "DayOfWeekName",    FORMAT([Date], "DDDD"),
				    "DayOfWeekShort",   FORMAT([Date], "DDD"),
				    "WeekOfYear",       WEEKNUM([Date], 2),
				    "DayOfYear",        DATEDIFF(DATE(YEAR([Date]), 1, 1), [Date], DAY) + 1,
				    
				    -- Useful combinations
				    "YearMonth",        YEAR([Date]) * 100 + MONTH([Date]),
				    "YearMonthName",    FORMAT([Date], "YYYY MMM"),
				    "YearQuarter",      YEAR([Date]) * 10 + QUARTER([Date]),
				    "YearQuarterName",  FORMAT([Date], "YYYY") & " Q" & QUARTER([Date]),
				    
				    -- Flags
				    "IsWeekend",        IF(WEEKDAY([Date], 2) >= 6, TRUE, FALSE),
				    "IsWeekday",        IF(WEEKDAY([Date], 2) < 6, TRUE, FALSE),
				    "IsLeapYear",       IF(DAY(DATE(YEAR([Date]), 3, 1) - 1) = 29, TRUE, FALSE),
				    
				    -- Relative periods (dynamic based on today)
				    "IsCurrentYear",    IF(YEAR([Date]) = YEAR(TODAY()), TRUE, FALSE),
				    "IsCurrentMonth",   IF(YEAR([Date]) = YEAR(TODAY()) && MONTH([Date]) = MONTH(TODAY()), TRUE, FALSE),
				    "IsCurrentQuarter", IF(YEAR([Date]) = YEAR(TODAY()) && QUARTER([Date]) = QUARTER(TODAY()), TRUE, FALSE),
				    "IsPastDate",       IF([Date] < TODAY(), TRUE, FALSE),
				    "IsFutureDate",     IF([Date] > TODAY(), TRUE, FALSE)
				)
				```

	annotation PBI_Id = 545b8625e06d4fb9995146b95c378be7

